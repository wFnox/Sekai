{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sekai",
  "version": "0.3.4",
  "identifier": "Sekai-app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Sekai",
        "width": 1000,
        "height": 680,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZFQUREMDFDODFBQzY3RDcKUldUWFo2eUJITkN0YmpEZDRPYWZINkNCcVRFaW9vUUszUTBxQWsybmlWSVp3a0xoSGM3NjEyRk0K",
      "endpoints": [
        "https://github.com/wFnox/Sekai/releases/latest/download/latest.json"
      ]
    }
  }
}
